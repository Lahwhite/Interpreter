// 1. char 到 int 的符号扩展测试
(int) 'A' + (int) 'Z'

// 2. int 到 char 的有符号 8 位截断测试
(char) 65 + (char) 90

// 3. 嵌套类型转换测试
(int) (char) 97 + (char) (int) 'M'

// 4. 混合运算中的类型转换
(int) 'a' * 2 + (char) (65 + 32)

// 5. 边界值测试
(int) '!' + (char) 125

// 6. 负数转换测试
(int) '@' + (char) -65

// 7. 表达式中的类型转换
(int) ('a' + 1) + (char) (90 - 1)

// 8. 连续类型转换
(char) (int) (char) 80 + (int) (char) 100